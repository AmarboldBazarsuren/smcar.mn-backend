# ================================
# SERVER ТОХИРГОО
# ================================
PORT=5000
NODE_ENV=development

# ================================
# MONGODB ХОЛБОЛТ
# ================================
# MongoDB Atlas эсвэл локал
MONGODB_URI=mongodb://localhost:27017/car_marketplace

# ================================
# CARAPIS / ENCAR API ТҮЛХҮҮР
# ================================
# https://carapis.com дээр бүртгүүлж API key аваарай
CARAPIS_API_KEY=your_api_key_here
CARAPIS_BASE_URL=https://api.carapis.com/encar

# ================================
# AUTO-SYNC ТОХИРГОО
# ================================
# Хэдэн минут тутамд шинэчлэх (default: 30 минут)
SYNC_INTERVAL_MINUTES=30
# Нэг удаад хэдэн машин татах
SYNC_BATCH_SIZE=100

# ================================
# JWT (Хэрэглэгч нэвтрэх)
# ================================
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ================================
# CORS ТОХИРГОО
# ================================
# Frontend-ийн хаяг
FRONTEND_URL=http://localhost:3000

# ================================
# RATE LIMITING
# ================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
